# MacroFX Terminal — API Keys
# Copy this file to .env and fill in your keys
# In the app, enter keys in the Config tab — they are stored in memory only

# FRED (Federal Reserve Economic Data)
# Get free key at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# Alpha Vantage — free tier: 25 requests/day
# Get free key at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here

# Twelve Data (optional — free tier: 800 requests/day)
# Get free key at: https://twelvedata.com/apikey
TWELVE_DATA_KEY=your_twelve_data_key_here
